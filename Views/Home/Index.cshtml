@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumb"] = @"<li class=""breadcrumb-item text-muted""><a href=""/"" class=""text-muted text-hover-primary"">Home</a></li>
        <li class=""breadcrumb-item""><span class=""bullet bg-gray-500 w-5px h-2px""></span></li>
        <li class=""breadcrumb-item text-muted"">Dashboard</li>";
}

<!-- Stats Row -->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">

    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3 mb-md-5 mb-xl-10">
        <div class="card card-flush h-md-50 mb-5 mb-xl-10">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">0</span>
                    <span class="text-gray-500 pt-1 fw-semibold fs-6">Total Records</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between fw-bold fs-6 text-gray-500 w-100 mt-auto mb-2">
                        <span>Active</span><span>0%</span>
                    </div>
                    <div class="h-8px mx-3 w-100 bg-light-success rounded">
                        <div class="bg-success rounded h-8px" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3 mb-md-5 mb-xl-10">
        <div class="card card-flush h-md-50 mb-5 mb-xl-10">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">0</span>
                    <span class="text-gray-500 pt-1 fw-semibold fs-6">Pending Tasks</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between fw-bold fs-6 text-gray-500 w-100 mt-auto mb-2">
                        <span>Completion</span><span>0%</span>
                    </div>
                    <div class="h-8px mx-3 w-100 bg-light-warning rounded">
                        <div class="bg-warning rounded h-8px" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3 mb-md-5 mb-xl-10">
        <div class="card card-flush h-md-50 mb-5 mb-xl-10">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">0</span>
                    <span class="text-gray-500 pt-1 fw-semibold fs-6">New Users</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between fw-bold fs-6 text-gray-500 w-100 mt-auto mb-2">
                        <span>Growth</span><span>0%</span>
                    </div>
                    <div class="h-8px mx-3 w-100 bg-light-primary rounded">
                        <div class="bg-primary rounded h-8px" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-6 col-xl-6 col-xxl-3 mb-md-5 mb-xl-10">
        <div class="card card-flush h-md-50 mb-5 mb-xl-10">
            <div class="card-header pt-5">
                <div class="card-title d-flex flex-column">
                    <span class="fs-2hx fw-bold text-gray-900 me-2 lh-1 ls-n2">0</span>
                    <span class="text-gray-500 pt-1 fw-semibold fs-6">Revenue</span>
                </div>
            </div>
            <div class="card-body d-flex align-items-end pt-0">
                <div class="d-flex align-items-center flex-column mt-3 w-100">
                    <div class="d-flex justify-content-between fw-bold fs-6 text-gray-500 w-100 mt-auto mb-2">
                        <span>Target</span><span>0%</span>
                    </div>
                    <div class="h-8px mx-3 w-100 bg-light-danger rounded">
                        <div class="bg-danger rounded h-8px" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Welcome Card -->
<div class="row g-5 g-xl-10">
    <div class="col-12">
        <div class="card">
            <div class="card-header border-0 pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold fs-3 mb-1">Welcome to CleanrApp</span>
                    <span class="text-muted mt-1 fw-semibold fs-7">Your dashboard is ready</span>
                </h3>
            </div>
            <div class="card-body py-3">
                <div class="notice d-flex bg-light-primary rounded border-primary border border-dashed p-6">
                    <i class="bi bi-info-circle fs-2tx text-primary me-4"></i>
                    <div class="d-flex flex-stack flex-grow-1">
                        <div class="fw-semibold">
                            <h4 class="text-gray-900 fw-bold">Getting Started</h4>
                            <div class="fs-6 text-gray-700">
                                Your .NET Core MVC application with Metronic theme is running successfully.
                                Add your controllers, models, and views to start building your application.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
