@model CleanrApp.ViewModels.CreateUnitViewModel
@using CleanrApp.Models
@{
    ViewData["Title"] = "إضافة وحدة جديدة";
    var buildings = ViewBag.Buildings as List<Building> ?? new();
    var customers = ViewBag.Customers as IList<ApplicationUser> ?? new List<ApplicationUser>();
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">إضافة وحدة جديدة</h3>
                <div class="card-toolbar">
                    <a asp-action="Units" class="btn btn-sm btn-light"><i class="bi bi-arrow-right me-1"></i>عودة</a>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="CreateUnit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-5"></div>
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="UnitNumber" class="form-label required fw-semibold">رقم الوحدة</label>
                            <input asp-for="UnitNumber" class="form-control" placeholder="مثال: 101" />
                            <span asp-validation-for="UnitNumber" class="text-danger fs-7"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BuildingId" class="form-label required fw-semibold">المبنى</label>
                            <select asp-for="BuildingId" class="form-select" required>
                                <option value="">-- اختر المبنى --</option>
                                @foreach (var b in buildings)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UnitType" class="form-label fw-semibold">نوع الوحدة</label>
                            <select asp-for="UnitType" class="form-select">
                                <option value="1">شقة</option>
                                <option value="2">غرفة فندقية</option>
                                <option value="3">فيلا</option>
                                <option value="4">استوديو</option>
                                <option value="5">جناح</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Floor" class="form-label fw-semibold">الطابق</label>
                            <input asp-for="Floor" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-12">
                            <label asp-for="CustomerId" class="form-label fw-semibold">تعيين للعميل</label>
                            <select asp-for="CustomerId" class="form-select">
                                <option value="">-- بدون عميل --</option>
                                @foreach (var c in customers)
                                {
                                    <option value="@c.Id">@c.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">وصف</label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="separator my-7"></div>
                    <div class="d-flex justify-content-end gap-3">
                        <a asp-action="Units" class="btn btn-light">إلغاء</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>إضافة الوحدة</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
