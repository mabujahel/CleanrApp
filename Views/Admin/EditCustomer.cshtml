@model CleanrApp.ViewModels.EditUserViewModel
@using CleanrApp.Models
@{
    ViewData["Title"] = "تعديل بيانات العميل";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">تعديل بيانات العميل</h3>
                <div class="card-toolbar">
                    <a asp-action="Customers" class="btn btn-sm btn-light"><i class="bi bi-arrow-right me-1"></i>عودة</a>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="EditCustomer" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-5"></div>
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label required fw-semibold">الاسم الكامل</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger fs-7"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">رقم الجوال</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AllowedVisits" class="form-label fw-semibold">الزيارات المسموح بها</label>
                            <input asp-for="AllowedVisits" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold">الحالة</label>
                            <select asp-for="Status" class="form-select">
                                <option value="1">نشط</option>
                                <option value="2">غير نشط</option>
                                <option value="3">موقوف</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-semibold">ملاحظات</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="separator my-7"></div>
                    <div class="d-flex justify-content-end gap-3">
                        <a asp-action="Customers" class="btn btn-light">إلغاء</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>حفظ التعديلات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
