@model CleanrApp.Models.CleaningRequest
@using CleanrApp.Models
@{
    ViewData["Title"] = $"طلب #{Model.RequestNumber}";
    var supervisors = ViewBag.Supervisors as List<ApplicationUser> ?? new();
    var cleaners = ViewBag.Cleaners as List<ApplicationUser> ?? new();
}

<div class="row g-5">
    <!-- Request Info -->
    <div class="col-lg-8">
        <div class="card mb-5">
            <div class="card-header">
                <h3 class="card-title">تفاصيل الطلب</h3>
                <div class="card-toolbar">
                    <partial name="_StatusBadge" model="Model.Status" />
                </div>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="symbol symbol-40px bg-light-primary rounded"><span class="symbol-label"><i class="bi bi-hash text-primary fs-4"></i></span></div>
                                <div><div class="text-muted fs-8">رقم الطلب</div><div class="fw-bold">@Model.RequestNumber</div></div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="symbol symbol-40px bg-light-info rounded"><span class="symbol-label"><i class="bi bi-person text-info fs-4"></i></span></div>
                                <div><div class="text-muted fs-8">العميل</div><div class="fw-bold">@Model.Customer?.FullName</div><div class="text-muted fs-8">@Model.Customer?.PhoneNumber</div></div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="symbol symbol-40px bg-light-warning rounded"><span class="symbol-label"><i class="bi bi-building text-warning fs-4"></i></span></div>
                                <div><div class="text-muted fs-8">الوحدة</div><div class="fw-bold">وحدة @Model.Unit?.UnitNumber</div><div class="text-muted fs-8">@Model.Unit?.Building?.Name - الطابق @Model.Unit?.Floor</div></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="symbol symbol-40px bg-light-success rounded"><span class="symbol-label"><i class="bi bi-calendar3 text-success fs-4"></i></span></div>
                                <div><div class="text-muted fs-8">تاريخ الإنشاء</div><div class="fw-bold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div>
                            </div>
                            @if (Model.ScheduledAt.HasValue)
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px bg-light-primary rounded"><span class="symbol-label"><i class="bi bi-clock text-primary fs-4"></i></span></div>
                                    <div><div class="text-muted fs-8">الموعد المحدد</div><div class="fw-bold">@Model.ScheduledAt.Value.ToString("dd/MM/yyyy HH:mm")</div></div>
                                </div>
                            }
                            @if (Model.CompletedAt.HasValue)
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px bg-light-success rounded"><span class="symbol-label"><i class="bi bi-check2 text-success fs-4"></i></span></div>
                                    <div><div class="text-muted fs-8">تاريخ الإنجاز</div><div class="fw-bold">@Model.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")</div></div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ServiceDescription))
                {
                    <div class="separator my-5"></div>
                    <h6 class="text-muted mb-3">وصف الخدمة</h6>
                    <p class="text-dark">@Model.ServiceDescription</p>
                }

                <!-- Services -->
                <div class="separator my-5"></div>
                <h6 class="text-muted mb-3">الخدمات الإضافية</h6>
                <div class="d-flex flex-wrap gap-3">
                    @if (Model.ChangeBedSheet) { <span class="badge badge-light-primary py-2 px-3"><i class="bi bi-check me-1"></i>تغيير مفرش السرير</span> }
                    @if (Model.ChangeLinens) { <span class="badge badge-light-primary py-2 px-3"><i class="bi bi-check me-1"></i>تغيير الملايات</span> }
                    @if (Model.ChangePillowCases) { <span class="badge badge-light-primary py-2 px-3"><i class="bi bi-check me-1"></i>تغيير أكياس المخدات</span> }
                    @if (Model.MakeBed) { <span class="badge badge-light-primary py-2 px-3"><i class="bi bi-check me-1"></i>ترتيب السرير</span> }
                    @if (Model.CleanBathroom) { <span class="badge badge-light-info py-2 px-3"><i class="bi bi-check me-1"></i>تنظيف الحمام</span> }
                    @if (Model.CleanKitchen) { <span class="badge badge-light-info py-2 px-3"><i class="bi bi-check me-1"></i>تنظيف المطبخ</span> }
                </div>

                @if (!string.IsNullOrEmpty(Model.CleanerNotes))
                {
                    <div class="separator my-5"></div>
                    <h6 class="text-muted mb-3">ملاحظات العامل</h6>
                    <div class="notice d-flex bg-light-success rounded border-success border border-dashed p-4">
                        <i class="bi bi-person-workspace fs-3 text-success me-3"></i>
                        <span>@Model.CleanerNotes</span>
                    </div>
                }

                @if (Model.Status == RequestStatus.Cancelled)
                {
                    <div class="separator my-5"></div>
                    <div class="notice d-flex bg-light-danger rounded border-danger border border-dashed p-4">
                        <i class="bi bi-x-circle fs-3 text-danger me-3"></i>
                        <div><div class="fw-bold text-danger">سبب الإلغاء</div><span>@Model.CancellationReason</span></div>
                    </div>
                }
            </div>
        </div>

        <!-- Photos -->
        @if (Model.Photos.Any())
        {
            <div class="card mb-5">
                <div class="card-header"><h3 class="card-title">صور التنظيف (@Model.Photos.Count)</h3></div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var photo in Model.Photos)
                        {
                            <div class="col-sm-6 col-md-4">
                                <div class="card border">
                                    <img src="@photo.FilePath" class="card-img-top rounded-top" style="height:180px;object-fit:cover;"
                                         onerror="this.src='/img/no-image.png'" />
                                    <div class="card-body p-2">
                                        <span class="badge badge-light-primary fs-8">@photo.PhotoType</span>
                                        <span class="text-muted fs-8 d-block mt-1">@photo.UploadedAt.ToString("dd/MM HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Notes -->
        <div class="card mb-5">
            <div class="card-header">
                <h3 class="card-title">الملاحظات</h3>
            </div>
            <div class="card-body">
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                {
                    <div class="d-flex mb-4">
                        <div class="symbol symbol-35px me-4">
                            <span class="symbol-label bg-@(note.IsInternal ? "light-danger" : "light-primary") rounded-circle">
                                <i class="bi bi-person @(note.IsInternal ? "text-danger" : "text-primary")"></i>
                            </span>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">@note.Author?.FullName</span>
                                <span class="text-muted fs-8">@note.CreatedAt.ToString("dd/MM HH:mm")</span>
                            </div>
                            <div class="text-gray-700">@note.Content</div>
                            @if (note.IsInternal) { <span class="badge badge-light-danger fs-8">داخلي</span> }
                        </div>
                    </div>
                }

                <form asp-action="AddNote" method="post" class="mt-4">
                    <input type="hidden" name="requestId" value="@Model.Id" />
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <textarea name="content" class="form-control" rows="3" placeholder="أضف ملاحظة..." required></textarea>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="form-check">
                            <input type="checkbox" name="isInternal" value="true" class="form-check-input" id="isInternal" />
                            <label class="form-check-label text-muted" for="isInternal">ملاحظة داخلية (لا تظهر للعميل)</label>
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary ms-auto">
                            <i class="bi bi-send me-1"></i>إضافة
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Audit Log -->
        @if (Model.AuditLogs.Any())
        {
            <div class="card">
                <div class="card-header"><h3 class="card-title">سجل النشاطات</h3></div>
                <div class="card-body p-0">
                    <div class="timeline-label ps-5 py-5">
                        @foreach (var log in Model.AuditLogs.OrderByDescending(a => a.CreatedAt))
                        {
                            <div class="timeline-item">
                                <div class="timeline-label fw-bold text-gray-800 fs-8 w-auto ms-3">@log.CreatedAt.ToString("dd/MM HH:mm")</div>
                                <div class="timeline-badge"><i class="bi bi-circle-fill text-primary fs-10"></i></div>
                                <div class="fw-semibold text-gray-700 ps-3">
                                    <span class="text-dark">@log.User?.FullName</span>: @log.Action
                                    @if (!string.IsNullOrEmpty(log.Details)) { <span class="text-muted"> - @log.Details</span> }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Actions Panel -->
    <div class="col-lg-4">
        <!-- Assign -->
        @if (Model.Status != RequestStatus.AdminApproved && Model.Status != RequestStatus.Cancelled)
        {
            <div class="card mb-5">
                <div class="card-header"><h3 class="card-title">تعيين المهمة</h3></div>
                <div class="card-body">
                    <form asp-action="AssignRequest" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RequestId" value="@Model.Id" />
                        <div class="mb-4">
                            <label class="form-label fw-semibold">تعيين مشرف</label>
                            <select name="SupervisorId" class="form-select">
                                <option value="">-- اختر مشرف --</option>
                                @foreach (var s in supervisors)
                                {
                                    <option value="@s.Id" selected="@(Model.SupervisorId == s.Id)">@s.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">تعيين عامل</label>
                            <select name="CleanerId" class="form-select">
                                <option value="">-- اختر عامل --</option>
                                @foreach (var c in cleaners)
                                {
                                    <option value="@c.Id" selected="@(Model.CleanerId == c.Id)">@c.FullName</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-check me-2"></i>تعيين
                        </button>
                    </form>
                </div>
            </div>

            <!-- Final Approve -->
            @if (Model.Status == RequestStatus.SupervisorApproved || Model.Status == RequestStatus.Done)
            {
                <div class="card mb-5 border-success">
                    <div class="card-body text-center py-6">
                        <i class="bi bi-patch-check text-success fs-3x mb-3 d-block"></i>
                        <h5 class="fw-bold mb-2">الاعتماد النهائي</h5>
                        <p class="text-muted fs-7 mb-4">سيتم خصم زيارة من رصيد العميل</p>
                        <form asp-action="ApproveRequest" method="post"
                              onsubmit="return confirm('هل تريد الاعتماد النهائي؟ سيتم خصم زيارة من رصيد العميل.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check2-circle me-2"></i>اعتماد نهائي
                            </button>
                        </form>
                    </div>
                </div>
            }

            <!-- Cancel -->
            <div class="card border-danger">
                <div class="card-header bg-light-danger border-0">
                    <h3 class="card-title text-danger">إلغاء الطلب</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CancelRequest" method="post"
                          onsubmit="return confirm('هل أنت متأكد من إلغاء هذا الطلب؟')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RequestId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">سبب الإلغاء <span class="text-danger">*</span></label>
                            <textarea name="Reason" class="form-control" rows="3" required placeholder="اكتب سبب الإلغاء..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-x-circle me-2"></i>إلغاء الطلب
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (Model.Status == RequestStatus.AdminApproved)
        {
            <div class="card border-success">
                <div class="card-body text-center py-8">
                    <i class="bi bi-patch-check-fill text-success fs-3x mb-3 d-block"></i>
                    <h4 class="fw-bold text-success">تم الاعتماد النهائي</h4>
                    <p class="text-muted">@Model.ApprovedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
        }

        <!-- Back -->
        <div class="mt-5">
            <a asp-action="Requests" class="btn btn-light w-100">
                <i class="bi bi-arrow-right me-2"></i>العودة للطلبات
            </a>
        </div>
    </div>
</div>
