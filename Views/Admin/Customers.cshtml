@model List<CleanrApp.Models.ApplicationUser>
@using CleanrApp.Models
@{
    ViewData["Title"] = "إدارة العملاء";
}

<div class="card">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title">
            <span class="card-label fw-bold fs-3">العملاء</span>
            <span class="text-muted mt-1 fw-semibold fs-7 ms-3">(@Model.Count عميل)</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="CreateCustomer" class="btn btn-primary btn-sm">
                <i class="bi bi-person-plus me-2"></i>إضافة عميل
            </a>
        </div>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4">العميل</th>
                        <th>البريد الإلكتروني</th>
                        <th>الجوال</th>
                        <th>الزيارات المتبقية</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="symbol symbol-40px symbol-circle bg-light-primary">
                                        <span class="symbol-label fw-bold text-primary">@user.FullName.Substring(0, 1)</span>
                                    </div>
                                    <div>
                                        <span class="fw-bold text-dark d-block">@user.FullName</span>
                                        <span class="text-muted fs-8">منذ @user.CreatedAt.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>@(user.PhoneNumber ?? "—")</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-bold @(user.AllowedVisits - user.UsedVisits <= 2 ? "text-danger" : "text-success")">
                                        @(user.AllowedVisits - user.UsedVisits)
                                    </span>
                                    <span class="text-muted fs-8">/ @user.AllowedVisits</span>
                                </div>
                            </td>
                            <td>
                                @if (user.Status == UserStatus.Active)
                                {
                                    <span class="badge badge-light-success">نشط</span>
                                }
                                else
                                {
                                    <span class="badge badge-light-danger">موقوف</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditCustomer" asp-route-id="@user.Id"
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1" title="تعديل">
                                    <i class="bi bi-pencil fs-5"></i>
                                </a>
                                @if (user.Status == UserStatus.Active)
                                {
                                    <form asp-action="DeleteCustomer" method="post" class="d-inline"
                                          onsubmit="return confirm('هل تريد إيقاف هذا العميل؟')">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-icon btn-bg-light btn-active-color-danger btn-sm" title="إيقاف">
                                            <i class="bi bi-person-x fs-5"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-15">
                            <i class="bi bi-people fs-2tx text-gray-300 d-block mb-4"></i>
                            لا يوجد عملاء
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
