@model CleanrApp.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "إضافة عامل تنظيف";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">إضافة عامل تنظيف جديد</h3>
                <div class="card-toolbar"><a asp-action="Cleaners" class="btn btn-sm btn-light"><i class="bi bi-arrow-right me-1"></i>عودة</a></div>
            </div>
            <div class="card-body">
                <form asp-action="CreateCleaner" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-5"></div>
                    <div class="row g-5">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label required fw-semibold">الاسم الكامل</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger fs-7"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">رقم الجوال</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label required fw-semibold">البريد الإلكتروني</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger fs-7"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label required fw-semibold">كلمة المرور</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger fs-7"></span>
                        </div>
                    </div>
                    <div class="separator my-7"></div>
                    <div class="d-flex justify-content-end gap-3">
                        <a asp-action="Cleaners" class="btn btn-light">إلغاء</a>
                        <button type="submit" class="btn btn-success"><i class="bi bi-person-plus me-2"></i>إضافة العامل</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
