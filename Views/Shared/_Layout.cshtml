<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CleanrApp</title>

    <!-- Google Fonts: Cairo -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons CDN (أيقونات فقط - خفيفة جداً) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Bootstrap RTL (محلي) -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />

    <!-- Metronic-style Theme (محلي) -->
    <link href="~/css/metronic-theme.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Mobile Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ============ SIDEBAR ============ -->
<div class="app-sidebar" id="appSidebar">
    <div class="app-sidebar-logo">
        <a href="/">
            <div class="logo-icon">
                <i class="bi bi-building-check text-white fs-5"></i>
            </div>
            <span class="logo-title ms-2">CleanrApp</span>
        </a>
    </div>

    <div class="app-sidebar-menu">
        @if (User.IsInRole("Admin"))
        {
            @await Html.PartialAsync("_AdminSidebar")
        }
        else if (User.IsInRole("Supervisor"))
        {
            @await Html.PartialAsync("_SupervisorSidebar")
        }
        else if (User.IsInRole("Cleaner"))
        {
            @await Html.PartialAsync("_CleanerSidebar")
        }
        else if (User.IsInRole("Customer"))
        {
            @await Html.PartialAsync("_CustomerSidebar")
        }
    </div>

    <div class="app-sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger w-100 btn-sm">
                <i class="bi bi-box-arrow-right me-2"></i>تسجيل الخروج
            </button>
        </form>
    </div>
</div>

<!-- ============ HEADER ============ -->
<div class="app-header">
    <div class="app-header-inner">
        <div class="d-flex align-items-center gap-3">
            <!-- Mobile toggle -->
            <button class="header-btn d-lg-none" onclick="toggleSidebar()">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="header-breadcrumb">
                <h1 class="header-title">@(ViewData["Title"] ?? "CleanrApp")</h1>
            </div>
        </div>

        <div class="header-actions">

            <!-- Notifications -->
            <div class="dropdown">
                <button class="header-btn" data-bs-toggle="dropdown" data-bs-auto-close="outside" id="notifBtn">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="notif-badge d-none" id="notifBadge">0</span>
                </button>
                <div class="dropdown-menu notif-dropdown p-0" style="min-width:360px;">
                    <div class="notif-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-white fw-bold fs-6">الإشعارات</div>
                                <div class="text-white opacity-50 fs-8" id="notifCount">جاري التحميل...</div>
                            </div>
                            <button onclick="markAllRead()" class="btn btn-sm btn-light-primary text-white" style="background:rgba(255,255,255,0.15);border:none;">
                                تعليم الكل
                            </button>
                        </div>
                    </div>
                    <div style="max-height:300px;overflow-y:auto;" id="notifList">
                        <div class="text-center text-muted py-5 fs-8">جاري التحميل...</div>
                    </div>
                </div>
            </div>

            <!-- User menu -->
            <div class="dropdown">
                <div class="d-flex align-items-center gap-2 cursor-pointer" data-bs-toggle="dropdown" style="cursor:pointer;">
                    <div class="user-avatar">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper())
                    </div>
                    <div class="d-none d-md-block text-end">
                        <div class="fw-semibold text-dark fs-7">@(User.Identity?.Name?.Split('@')[0])</div>
                        @if (User.IsInRole("Admin"))      { <small class="text-muted fs-8">مدير النظام</small> }
                        @if (User.IsInRole("Supervisor")) { <small class="text-muted fs-8">مشرف</small> }
                        @if (User.IsInRole("Cleaner"))    { <small class="text-muted fs-8">عامل تنظيف</small> }
                        @if (User.IsInRole("Customer"))   { <small class="text-muted fs-8">عميل</small> }
                    </div>
                    <i class="bi bi-chevron-down text-muted fs-8 d-none d-md-block"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li class="px-3 py-2 border-bottom">
                        <div class="fw-bold text-dark">@User.Identity?.Name?.Split('@')[0]</div>
                        <div class="text-muted fs-8">@User.Identity?.Name</div>
                    </li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i>تسجيل الخروج
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ============ MAIN ============ -->
<div class="app-main">
    <div class="app-content">
        <!-- Success/Error Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-3 mb-4" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div class="flex-grow-1">@TempData["Success"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-3 mb-4" role="alert">
                <i class="bi bi-exclamation-circle-fill fs-5"></i>
                <div class="flex-grow-1">@TempData["Error"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <div class="app-footer">
        <div class="d-flex justify-content-between align-items-center">
            <span>&copy; @DateTime.Now.Year CleanrApp — نظام إدارة خدمات التنظيف</span>
            <span class="text-muted">v1.0.0</span>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Scripts (محلي) -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<!-- SignalR (محلي) -->
<script src="~/js/signalr.min.js"></script>

<script>
    // ===== Sidebar Toggle (Mobile) =====
    function toggleSidebar() {
        document.getElementById('appSidebar').classList.toggle('open');
        document.getElementById('sidebarOverlay').classList.toggle('show');
    }
    function closeSidebar() {
        document.getElementById('appSidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('show');
    }

    // ===== Active Menu Link =====
    const currentPath = window.location.pathname.toLowerCase();
    document.querySelectorAll('.menu-link').forEach(link => {
        const href = link.getAttribute('href');
        if (href && currentPath.startsWith(href.toLowerCase()) && href !== '/') {
            link.classList.add('active');
            if (link.querySelector('.menu-icon')) {
                link.querySelector('.menu-icon').style.background = 'var(--primary)';
                link.querySelector('.menu-icon').style.color = 'white';
            }
        }
    });

    // ===== Notifications =====
    async function loadNotifications() {
        try {
            const res = await fetch('/Notifications/GetUnread');
            const data = await res.json();
            const badge = document.getElementById('notifBadge');
            const count = document.getElementById('notifCount');
            const list  = document.getElementById('notifList');

            if (data.count > 0) {
                badge.textContent = data.count > 99 ? '99+' : data.count;
                badge.classList.remove('d-none');
                count.textContent = data.count + ' إشعار غير مقروء';
            } else {
                badge.classList.add('d-none');
                count.textContent = 'لا توجد إشعارات جديدة';
            }

            if (data.notifications && data.notifications.length > 0) {
                list.innerHTML = data.notifications.map(n => `
                    <div class="d-flex align-items-start gap-3 p-3 border-bottom ${!n.isRead ? 'bg-light' : ''}">
                        <div class="flex-shrink-0 mt-1">
                            <div class="symbol-35px symbol-circle">
                                <span class="d-flex align-items-center justify-content-center" style="width:34px;height:34px;border-radius:50%;background:rgba(0,158,247,0.1);">
                                    <i class="bi bi-bell text-primary"></i>
                                </span>
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold text-dark fs-7">${n.title}</div>
                            <div class="text-muted fs-8 mt-1">${n.message}</div>
                        </div>
                    </div>
                `).join('');
            } else {
                list.innerHTML = '<div class="text-center text-muted py-6 fs-8"><i class="bi bi-bell-slash d-block fs-2 mb-2"></i>لا توجد إشعارات</div>';
            }
        } catch(e) {
            document.getElementById('notifCount').textContent = 'تعذر التحميل';
        }
    }

    async function markAllRead() {
        const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;
        await fetch('/Notifications/MarkAllRead', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token || '' }
        });
        loadNotifications();
    }

    // Load on dropdown open
    document.getElementById('notifBtn')?.addEventListener('click', loadNotifications);
    // Load on page load (badge only)
    setTimeout(loadNotifications, 500);

    // ===== Toast Function =====
    function showToast(title, message, type = 'primary') {
        const icons = { primary: 'bi-bell', success: 'bi-check-circle', danger: 'bi-exclamation-circle', warning: 'bi-exclamation-triangle' };
        const toast = document.createElement('div');
        toast.className = 'toast-cleanr';
        toast.innerHTML = `
            <div style="width:36px;height:36px;border-radius:50%;background:rgba(0,158,247,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi ${icons[type] || icons.primary} text-${type}"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-bold text-dark fs-7">${title}</div>
                <div class="text-muted fs-8">${message}</div>
            </div>
            <button onclick="this.closest('.toast-cleanr').remove()" class="btn-close btn-close-sm ms-2"></button>
        `;
        document.getElementById('toastContainer').appendChild(toast);
        setTimeout(() => toast.remove(), 6000);
    }

    // ===== SignalR =====
    @if (User.Identity?.IsAuthenticated == true)
    {
        <text>
    try {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (notification) {
            showToast(notification.title, notification.message, 'primary');
            loadNotifications();
        });

        connection.start().catch(err => console.warn('SignalR:', err));
    } catch(e) { console.warn('SignalR not available'); }
        </text>
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
