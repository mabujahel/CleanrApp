@model List<CleanrApp.Models.CleaningRequest>
@using CleanrApp.Models
@{
    ViewData["Title"] = "لوحة المشرف";
}

<!-- Stats -->
<div class="row g-4 mb-7">
    <div class="col-6 col-xl-3">
        <div class="card bg-light-warning">
            <div class="card-body text-center py-5">
                <div class="fs-2x fw-bold text-warning">@ViewBag.Pending</div>
                <div class="text-gray-600 fs-7">قيد الانتظار</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card bg-light-info">
            <div class="card-body text-center py-5">
                <div class="fs-2x fw-bold text-info">@ViewBag.InProgress</div>
                <div class="text-gray-600 fs-7">جاري التنفيذ</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card bg-light-primary">
            <div class="card-body text-center py-5">
                <div class="fs-2x fw-bold text-primary">@ViewBag.Done</div>
                <div class="text-gray-600 fs-7">تم الانتهاء</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card bg-light-success">
            <div class="card-body text-center py-5">
                <div class="fs-2x fw-bold text-success">@ViewBag.Approved</div>
                <div class="text-gray-600 fs-7">معتمدة</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title"><span class="card-label fw-bold fs-3">طلباتي</span></h3>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table table-row-dashed table-row-gray-300 align-middle">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th>رقم الطلب</th><th>العميل</th><th>الوحدة</th><th>العامل</th><th>الموعد</th><th>الحالة</th><th>إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>
                            <td class="fw-bold">@req.RequestNumber</td>
                            <td>@req.Customer?.FullName</td>
                            <td>@req.Unit?.UnitNumber - @req.Unit?.Building?.Name</td>
                            <td>@(req.Cleaner?.FullName ?? "<span class='text-muted'>غير محدد</span>")</td>
                            <td class="text-muted fs-8">@req.ScheduledAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><partial name="_StatusBadge" model="req.Status" /></td>
                            <td>
                                <a asp-controller="Supervisor" asp-action="RequestDetail" asp-route-id="@req.Id"
                                   class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm">
                                    <i class="bi bi-eye fs-4"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-15">
                            <i class="bi bi-inbox fs-2tx text-gray-300 d-block mb-4"></i>
                            لا توجد طلبات مسندة إليك
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
