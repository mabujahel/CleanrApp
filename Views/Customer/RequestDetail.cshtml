@model CleanrApp.Models.CleaningRequest
@using CleanrApp.Models
@{
    ViewData["Title"] = $"طلب #{Model.RequestNumber}";
}

<div class="row g-5 justify-content-center">
    <div class="col-lg-8">
        <!-- Status Timeline -->
        <div class="card mb-5">
            <div class="card-body py-5">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h4 class="fw-bold mb-1">@Model.RequestNumber</h4>
                        <span class="text-muted fs-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <partial name="_StatusBadge" model="Model.Status" />
                </div>

                <!-- Progress Steps -->
                <div class="d-flex justify-content-between position-relative mb-2">
                    <div class="position-absolute top-50 translate-middle-y w-100 bg-gray-200" style="height:3px;z-index:0;left:0;"></div>
                    @{
                        int step = Model.Status switch {
                            RequestStatus.Pending => 1,
                            RequestStatus.Received or RequestStatus.AssignedSupervisor => 2,
                            RequestStatus.AssignedCleaner => 3,
                            RequestStatus.InProgress => 4,
                            RequestStatus.Done or RequestStatus.SupervisorApproved => 5,
                            RequestStatus.AdminApproved => 6,
                            _ => 0
                        };

                        var steps = new[] { "إنشاء الطلب", "استلام الإدارة", "تعيين عامل", "التنفيذ", "الانتهاء", "الاعتماد" };
                        for (int i = 0; i < steps.Length; i++) {
                            bool done = step > i + 1;
                            bool current = step == i + 1;
                            <div class="d-flex flex-column align-items-center position-relative" style="z-index:1;">
                                <div class="rounded-circle d-flex align-items-center justify-content-center mb-2"
                                     style="width:36px;height:36px;background:@(done ? "#50cd89" : current ? "#009ef7" : "#f5f8fa"); border:2px solid @(done ? "#50cd89" : current ? "#009ef7" : "#e4e6ef");">
                                    @if (done) { <i class="bi bi-check text-white"></i> }
                                    else if (current) { <span class="text-white fw-bold fs-8">@(i+1)</span> }
                                    else { <span class="text-muted fw-bold fs-8">@(i+1)</span> }
                                </div>
                                <span class="text-muted fs-9 text-center" style="max-width:60px;">@steps[i]</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="card mb-5">
            <div class="card-header"><h3 class="card-title">تفاصيل الطلب</h3></div>
            <div class="card-body">
                <div class="row g-4 mb-5">
                    <div class="col-6">
                        <div class="text-muted fs-8">الوحدة</div>
                        <div class="fw-bold">وحدة @Model.Unit?.UnitNumber</div>
                        <div class="text-muted fs-8">@Model.Unit?.Building?.Name</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted fs-8">الموعد المحدد</div>
                        <div class="fw-bold">@(Model.ScheduledAt?.ToString("dd/MM/yyyy HH:mm") ?? "فوري")</div>
                    </div>
                    @if (Model.CompletedAt.HasValue)
                    {
                        <div class="col-6">
                            <div class="text-muted fs-8">تاريخ الإنجاز</div>
                            <div class="fw-bold text-success">@Model.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.ServiceDescription))
                {
                    <div class="separator my-4"></div>
                    <h6 class="text-muted mb-2">وصف الخدمة</h6>
                    <p>@Model.ServiceDescription</p>
                }

                <div class="separator my-4"></div>
                <h6 class="text-muted mb-3">الخدمات المطلوبة</h6>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.ChangeBedSheet) { <span class="badge badge-light-primary py-2 px-3">تغيير المفرش</span> }
                    @if (Model.ChangeLinens) { <span class="badge badge-light-primary py-2 px-3">تغيير الملايات</span> }
                    @if (Model.ChangePillowCases) { <span class="badge badge-light-primary py-2 px-3">أكياس المخدات</span> }
                    @if (Model.MakeBed) { <span class="badge badge-light-primary py-2 px-3">ترتيب السرير</span> }
                    @if (Model.CleanBathroom) { <span class="badge badge-light-info py-2 px-3">تنظيف الحمام</span> }
                    @if (Model.CleanKitchen) { <span class="badge badge-light-info py-2 px-3">تنظيف المطبخ</span> }
                </div>
            </div>
        </div>

        <!-- Photos (after completion) -->
        @if (Model.Photos.Any())
        {
            <div class="card mb-5">
                <div class="card-header"><h3 class="card-title">صور ما بعد التنظيف</h3></div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var photo in Model.Photos)
                        {
                            <div class="col-sm-4">
                                <a href="@photo.FilePath" target="_blank">
                                    <img src="@photo.FilePath" class="img-fluid rounded shadow-sm" style="height:150px;object-fit:cover;width:100%;" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Notes for customer (non-internal) -->
        @if (Model.Notes.Any())
        {
            <div class="card mb-5">
                <div class="card-header"><h3 class="card-title">الملاحظات</h3></div>
                <div class="card-body">
                    @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="d-flex mb-4">
                            <div class="symbol symbol-35px bg-light-primary me-3 rounded-circle">
                                <span class="symbol-label"><i class="bi bi-chat-square-text text-primary"></i></span>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-semibold">@note.Author?.FullName</span>
                                    <span class="text-muted fs-8">@note.CreatedAt.ToString("dd/MM HH:mm")</span>
                                </div>
                                <div class="text-gray-700">@note.Content</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.Status == RequestStatus.AdminApproved)
        {
            <div class="notice d-flex bg-light-success rounded border-success border border-dashed p-6 mb-5">
                <i class="bi bi-patch-check-fill text-success fs-2x me-4"></i>
                <div>
                    <h5 class="text-success fw-bold">تم الانتهاء من التنظيف</h5>
                    <p class="text-muted mb-0">تم تنظيف وحدتك وإعتمادها نهائياً. شكراً لاستخدامك CleanrApp.</p>
                </div>
            </div>
        }

        <a asp-action="Index" class="btn btn-light btn-lg w-100">
            <i class="bi bi-arrow-right me-2"></i>العودة
        </a>
    </div>
</div>
